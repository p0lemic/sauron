# dashboard.yaml.example — dashboard service
# Copy to dashboard.yaml and adjust values for your environment.
# All fields are optional; CLI flags override any value set here.

# Storage backend to read metrics from.
# Must point to the same database the proxy writes to.
storage:
  driver: sqlite                 # "sqlite" (default) | "postgres"
  dsn: profiler.db               # file path for sqlite, connection string for postgres

# Address where the dashboard HTTP server listens (default: :9090).
api_addr: ":9090"

# How far back to aggregate metrics (default: 30m).
metrics_window: 30m

# Number of past windows used to compute the baseline for anomaly detection (default: 5).
baseline_windows: 5

# Std-dev multiplier for anomaly detection — higher = less sensitive (default: 3.0).
anomaly_threshold: 3.0

# Optional webhook URL to POST alert notifications to.
# webhook_url: "https://hooks.example.com/alerts"

# Examples:
#
# Local dev (shared SQLite with proxy):
#   storage:
#     driver: sqlite
#     dsn: ./profiler.db
#
# ECS / AWS (shared PostgreSQL with proxy sidecar):
#   storage:
#     driver: postgres
#     dsn: "postgres://user:pass@rds-host.us-east-1.rds.amazonaws.com/profiler"
#   api_addr: ":9090"
